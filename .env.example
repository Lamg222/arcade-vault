# Configuración del envío de correo del formulario de contacto (/acerca).
# Copia este archivo a `.env.local` y coloca los valores reales.
# `.env.local` NO se versiona (está en .gitignore); este `.env.example` sí, como plantilla.

# Clave secreta de la API de Resend (https://resend.com/api-keys). Solo se lee en el servidor.
RESEND_API_KEY=

# Destinatario de las notificaciones del formulario.
# En el sandbox de Resend (onboarding@resend.dev) debe ser el email dueño de la cuenta Resend.
CONTACT_TO_EMAIL=

SUPABASE_BD_PASSWORD=
