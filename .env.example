# Configuración del envío de correo del formulario de contacto (/acerca).
# Copia este archivo a `.env.local` y coloca los valores reales.
# `.env.local` NO se versiona (está en .gitignore); este `.env.example` sí, como plantilla.

# Clave secreta de la API de Resend (https://resend.com/api-keys). Solo se lee en el servidor.
RESEND_API_KEY=

# Destinatario de las notificaciones del formulario.
# En el sandbox de Resend (onboarding@resend.dev) debe ser el email dueño de la cuenta Resend.
CONTACT_TO_EMAIL=

# --- Supabase (spec 04-integracion-supabase) ---
# Copia los valores desde el dashboard: Project Settings → API.

# URL del proyecto Supabase (p.ej. https://xxxx.supabase.co). Pública: se expone al navegador (prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima pública (anon key). Segura en el navegador porque RLS (Row Level Security — reglas por fila) limita qué puede leer/escribir. Pública (prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Contraseña de la base de datos Postgres (conexión directa: migraciones, psql, connection string). NO la usan los clientes de la app; secreta, solo servidor/CLI. Nunca con prefijo NEXT_PUBLIC_.
SUPABASE_BD_PASSWORD=
